    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.0",
    "openai": "^6.9.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.8"
  }
}
