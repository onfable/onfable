{
  "name": "onfable",
  "version": "0.1.1",
  "description": "The open-source autonomous AI agent that lives in your terminal. Runs commands, edits files, browses the web, and remembers you.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://onfable.xyz",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onfable/onfable.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/onfable/onfable/issues",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "assistant",
    "autonomous",
    "claude",
    "openai",
    "openrouter",
    "llm",
    "terminal"
  ],
  "bin": {
